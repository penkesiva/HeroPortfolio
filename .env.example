# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only: Settings → API → service_role (required for Stripe webhooks to update plan)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...
STRIPE_FAMILY_MONTHLY_PRICE_ID=price_...
STRIPE_FAMILY_ANNUAL_PRICE_ID=price_...

# ─── OpenAI (for AI Smart Import) ────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── App URL (used for Stripe redirect URLs) ─────────────────────────────────
NEXT_PUBLIC_APP_URL=https://heroportfolio.com

# ─── Google sign-in (configure in Supabase + Google Cloud Console) ───────────
# 1. Supabase Dashboard → Authentication → URL Configuration:
#    - Site URL: your production origin (e.g. https://heroportfolio.com)
#    - Additional Redirect URLs: http://localhost:3000/auth/callback
#      and https://heroportfolio.com/auth/callback (add www variant if you use it)
# 2. Supabase → Authentication → Providers → Google: enable, paste Web client ID + secret
# 3. Google Cloud Console → APIs & Services → Credentials → your OAuth client:
#    - Authorized redirect URI must include:
#      https://<YOUR_PROJECT_REF>.supabase.co/auth/v1/callback

# ─── Optional: force show the content editor in production ───────────────────
# NEXT_PUBLIC_CONTENT_EDITOR=true
